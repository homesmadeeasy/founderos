# ─── App identity ────────────────────────────────────────────────────────────
# local | staging | production — controls staging badge and docs expectations
NEXT_PUBLIC_APP_ENV=local
# Canonical origin for this environment (no trailing slash). Used for docs and
# future auth redirect helpers. Example: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (required) ─────────────────────────────────────────────────────
# Project URL and anon (public) key from: Supabase Dashboard → Project Settings → API
# The anon key is safe to expose client-side because Row Level Security protects data.
# NEVER put the service_role key in this app.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── OpenAI (optional for Founder AI; required for some AI API routes) ───────
# Server-side only. Never use NEXT_PUBLIC_ for these.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Optional model override for Founder AI (default: gpt-4o-mini)
OPENAI_FOUNDER_MODEL=gpt-4o-mini

# ─── Google Calendar (optional) ──────────────────────────────────────────────
# Integration stays disabled until all three are set. Server-side only.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback

# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
# Do not invent or commit SUPABASE_SERVICE_ROLE_KEY — RLS + anon key only.
